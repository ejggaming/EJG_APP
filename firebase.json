{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "api/**",
        "run": {
          "serviceId": "ejg-api-backend-dev",
          "region": "us-central1"
        }
      },
      {
        "source": "socket.io/**",
        "run": {
          "serviceId": "ejg-api-backend-dev",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
